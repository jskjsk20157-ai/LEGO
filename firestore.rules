rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: wishlists
    // Document ID: auto-generated
    // Fields:
    //   - number: string (required) - Lego set number
    //   - name: string (required) - Lego set name
    //   - image: string (required) - Image URL
    //   - addedAt: string (required) - ISO date string
    //   - uid: string (required) - Owner's UID
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['number', 'name', 'image', 'addedAt', 'uid']) &&
             data.number is string && data.number.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.image is string &&
             data.addedAt is string &&
             data.uid == request.auth.uid;
    }

    match /wishlists/{itemId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && isValidWishlistItem(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidWishlistItem(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /analysis_cache/{setNumber} {
      allow read: if true;
      allow write: if true; // Shared cache for performance
    }
  }
}
